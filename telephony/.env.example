# ── Telephony service env ──────────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env — and never put real values in
# THIS file, because this one IS committed.

# Local server port
PORT=8080

# Your public HTTPS host WITHOUT protocol (used to build the wss:// stream URL).
# In dev this is your ngrok host, e.g. abcd-1-2-3-4.ngrok-free.app
PUBLIC_HOSTNAME=

# Groq (the LLM brain) — https://console.groq.com
# gpt-oss-120b is required: it tool-calls natively. llama-3.3-70b wrote tool calls as
# literal <function=...> XML that the TTS read ALOUD to a caller — do not switch back.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Deepgram (speech-to-text) — https://console.deepgram.com
# nova-3 is required: it is the only model whose `language=multi` includes Hindi,
# which is what lets a caller code-switch mid-sentence.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Cartesia (text-to-speech) — https://play.cartesia.ai
# Deepgram Aura has no Hindi voice, so TTS lives here instead. Cartesia emits
# mu-law 8kHz natively, which is exactly what Twilio Media Streams wants.
# Run `npm run voices` to list Hindi voices and pick one.
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-3.5
CARTESIA_VOICE_ID=

# Twilio (telephony + SMS) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Supabase — Project Settings → API. Use the SERVICE ROLE key here (server-only!).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
